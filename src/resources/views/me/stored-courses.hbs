<form name="container-form"  class="mt-4" method="post" action="/courses/handle-form-actions">
  <div>
    <h1>Quản Lý Khóa Học Của Tôi</h1>
    <a href="/me/trash/courses">Thùng Rác ({{deletedCount}})</a>

    <div class="mt-4 d-flex align-items-center gap-2">
      <div class="form-check">
        <input class="form-check-input" type="checkbox" value="" id="checkbox-all">
        <label class="form-check-label" for="checkbox-all" >
          Chọn tất cả
        </label>
      </div>

      <select class="form-select form-select-sm checkbox-select-all-option" name="action" aria-label="Default select example" required >
        {{!-- <option selected disabled>Chọn hành động</option> --}}
        <option value="">--Hành Động--</option>
        <option value="delete">Xóa</option>
      </select>

      <button type="submit" class="btn btn-primary btn-sm check-all-submit" disabled>Thực hiện</button>
       
    </div>
  </div>
  <table class="table">
    <thead>
      <tr>
        <th scope="col" colspan="2">#</th>
        <th scope="col">Tên Khóa Học</th>
        <th scope="col">Cấp Độ</th>
        <th scope="col" colspan="2">Ngày Tạo</th>
      </tr>
    </thead>
    <tbody>
      {{#each courses}}
      <tr>
        <td>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="coursesIds[]" value="{{this._id}}" />
          </div>
        </td>
        <th scope="row">{{sum @index 1}}</th>
        <td>{{this.name}}</td>
        <td>{{this.level}}</td>
        <td>{{this.createdAt}}</td>

        <td>
          <a href="/courses/{{this._id}}/edit" class="btn btn-primary">Chỉnh Sửa</a>
          <a href="" class="btn btn-danger" data-bs-toggle="modal" data-id="{{this._id}}"
            data-bs-target="#deleteModal">Xóa</a>
        </td>
      </tr>
      {{else}}
      <tr>
        <td colspan="5" class="text-center">Bạn chưa có khóa học nào.
          <a href="/courses/create">Tạo khóa học mới</a>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</form>


{{!-- Confirm DELETE --}}
<div id="deleteModal" class="modal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Xóa Khóa Học</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Bạn có chắc chắn muốn xóa khóa học này không?</p>
      </div>
      <div class="modal-footer">
        <button id="btn-delete-course" type="button" class="btn btn-primary btn-danger">Xóa bỏ</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>

      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var courseId;
    var checkboxAll=$('#checkbox-all');
    var courseIteams=$('input[name="coursesIds[]"]');
    var checkAllSubmit=$('.check-all-submit');
    var containerForm=document.forms['container-form'];
    
    //When the delete modal is shown, get the course ID from the button that triggered the modal
    $('#deleteModal').on('show.bs.modal', function (event) {
      var button = $(event.relatedTarget); // Button that triggered the modal
      courseId = button.data('id'); // Extract info from data-* attributes
      console.log('Course ID:', courseId);
    });

    var btnDelete = document.getElementById('btn-delete-course');
    btnDelete.onclick = function () {
      console.log('Deleting course with ID:', courseId);
      // Create form and submit with DELETE method
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/courses/' + courseId + '?_method=DELETE';
      document.body.appendChild(form);
      form.submit();
    };

    // Select/Deselect all checkboxes
    checkboxAll.on('change', function() {
      var isChecked = $(this).is(':checked'); 
      courseIteams.prop('checked', isChecked);
      renderCheckAll();
    });
    
    //Course item check/uncheck logic
    courseIteams.on('change', function() {
      var allChecked = courseIteams.length === courseIteams.filter(':checked').length;
      checkboxAll.prop('checked', allChecked);
      renderCheckAll();
    });
    
    //Check all submit button click event
    checkAllSubmit.on('click', function(e) {
      e.preventDefault();
      var selectedAction = $('.checkbox-select-all-option').val();
      var checkedCount = courseIteams.filter(':checked').length;
      
      // Kiểm tra chưa chọn khóa học
      if(checkedCount === 0){
        alert('Vui lòng chọn ít nhất một khóa học');
        return;
      }
      
      // Kiểm tra chưa chọn hành động
      if(!selectedAction || selectedAction === ''){
        alert('Vui lòng chọn hành động');
        return;
      }
      
      console.log('Submitting form with action:', selectedAction);
      containerForm.submit();
    });

    // render check all button
    function renderCheckAll(){
      var checkedCount = courseIteams.filter(':checked').length;
      var actionButton = $('.check-all-submit');
      if(checkedCount>0){
        actionButton.prop('disabled', false);
      } else {
        actionButton.prop('disabled', true);
      }
    }
  });
</script>